{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "contextRole": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "\\S"
    },
    "keyExpressions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "meaningZh": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "pattern": "\\S"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300,
            "pattern": "^[^\\u3400-\\u9fff]*[A-Za-z][^\\u3400-\\u9fff]*$"
          }
        },
        "required": ["meaningZh", "text"]
      }
    },
    "mainStructure": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "\\S"
    },
    "selectionKind": {
      "type": "string",
      "const": "sentence"
    },
    "sourceText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "pattern": "\\S"
    },
    "translationZh": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "pattern": "\\S"
    },
    "type": {
      "type": "string",
      "const": "explain-sentence"
    }
  },
  "required": [
    "contextRole",
    "keyExpressions",
    "mainStructure",
    "selectionKind",
    "sourceText",
    "translationZh",
    "type"
  ]
}
