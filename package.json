{
  "name": "huayi",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "check:instructions": "node scripts/check-instructions.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "host:install": "node apps/native-host/dist/install/cli.js install",
    "host:compatible:key:configure": "node apps/native-host/dist/install/cli.js compatible-key-configure",
    "host:compatible:key:remove": "node apps/native-host/dist/install/cli.js compatible-key-remove",
    "host:compatible:config:set": "node apps/native-host/dist/install/cli.js compatible-config-set",
    "host:compatible:config:status": "node apps/native-host/dist/install/cli.js compatible-config-status",
    "host:compatible:config:remove": "node apps/native-host/dist/install/cli.js compatible-config-remove",
    "host:eudic:configure": "node apps/native-host/dist/install/cli.js eudic-configure",
    "host:eudic:remove": "node apps/native-host/dist/install/cli.js eudic-remove",
    "host:openai:configure": "node apps/native-host/dist/install/cli.js openai-configure",
    "host:openai:remove": "node apps/native-host/dist/install/cli.js openai-remove",
    "host:deepseek:configure": "node apps/native-host/dist/install/cli.js deepseek-configure",
    "host:deepseek:remove": "node apps/native-host/dist/install/cli.js deepseek-remove",
    "host:provider:set": "node apps/native-host/dist/install/cli.js provider-set",
    "host:provider:status": "node apps/native-host/dist/install/cli.js provider-status",
    "host:uninstall": "node apps/native-host/dist/install/cli.js uninstall",
    "lint": "eslint .",
    "smoke:codex": "node scripts/verify-ephemeral-session.mjs",
    "smoke:compatible": "node scripts/smoke-compatible.mjs",
    "smoke:deepseek": "node scripts/smoke-deepseek.mjs",
    "smoke:compare": "node scripts/compare-providers.mjs",
    "test": "node --test scripts/*.test.mjs && vitest run --workspace vitest.workspace.ts --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "typecheck": "pnpm --recursive --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.52.0",
    "@types/chrome": "^0.0.326",
    "@types/node": "^18.19.112",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
